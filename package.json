{
  "name": "task-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "supabase": "supabase",
    "db:login": "supabase login",
    "db:link": "supabase link",
    "db:migration:new": "supabase migration new",
    "db:migration:list": "supabase migration list",
    "db:pull": "supabase db pull",
    "db:push": "supabase db push",
    "db:dump": "supabase db dump --linked --schema public",
    "db:dump:file": "supabase db dump --linked --schema public --file schema-current.sql",
    "db:reset": "supabase db reset",
    "docker:up": "docker compose up --build",
    "docker:app": "docker compose up --build scheduler backend frontend",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./run-local-dev.ps1",
    "dev:local:install-python": "powershell -ExecutionPolicy Bypass -File ./run-local-dev.ps1 -InstallPythonDeps"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "supabase": "^2.108.0"
  }
}
