# Copy the PostgreSQL connection string from Supabase Dashboard > Connect.
# Use the Session pooler string when your network does not support direct IPv6 connections.
DATABASE_URL=postgresql://postgres.udmluccwgzabristvzma:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SSL=true
DATABASE_POOL_MAX=10

HOST=0.0.0.0
PORT=4000
# Optional comma-separated frontend origins. When omitted, development origins are accepted.
CORS_ORIGIN=http://localhost:5173,http://100.109.0.57:5173

# Optional. When OPENAI_API_KEY is set, GET /advisor uses AI to explain what to do next.
# Without it, the advisor still works with local prioritization rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional Google Calendar integration.
# Create an OAuth Client in Google Cloud Console and add this redirect URI:
# http://localhost:4000/google/oauth/callback
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/google/oauth/callback
# 32 random bytes. Example command:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=
